# Anthropic API Key (Claude)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Credentials for admin and user accounts
ADMIN_USERNAME="admin_username_here"
ADMIN_PASSWORD="admin_password_here"

USER_USERNAME="user_username_here"
USER_PASSWORD="user_password_here"

# Optional: Default model (can override in UI)
DEFAULT_MODEL="claude-sonnet-4-6"

# Optional: App environment
ENV="development"

# Optional: Debug mode
DEBUG="true"