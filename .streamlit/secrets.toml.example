# Anthropic API Key (Claude)
[api_keys]
anthropic = "your_anthropic_api_key_here"

# Credentials for admin and users
[auth]
password_pepper = "some_random_pepper_value_here"  # ⚠️ replace with a secure random string

# Admin credentials
[auth.admin]
username = "admin_username_here"
password = "admin_password_here"  # ⚠️ replace with password_hash ideally

# User credentials (you can add multiple users)
[[auth.users]]
username = "user_username_here"
password = "user_password_here"  # ⚠️ replace with password_hash
[[auth.users]]
username = "user_username_here"
password = "user_password_here"  # ⚠️ replace with password_hash
[[auth.users]]
username = "user_username_here"
password = "user_password_here"  # ⚠️ replace with password_hash

# Supabase credentials
[supabase]
url = "https://your-project.supabase.co"
key = "your_supabase_key"


# App settings
[app]
default_model = "claude-sonnet-4-6"
env = "development"
debug = true