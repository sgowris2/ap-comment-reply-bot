# =============================================================
#  ap-comment-reply-bot — .gitignore
# =============================================================
.idea/

# -------------------------------------------------------------
# Environment & secrets — NEVER commit these
# -------------------------------------------------------------
.env
.env.local
.env.*.local


# -------------------------------------------------------------
# Python
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log

# -------------------------------------------------------------
# Runtime artefacts produced by the app
# -------------------------------------------------------------
new_terms_*.log


# -------------------------------------------------------------
# PyCharm (Community or Professional)
# -------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
shelf/
workspace.xml

# -------------------------------------------------------------
# VS Code
# -------------------------------------------------------------
.vscode/
*.code-workspace

# -------------------------------------------------------------
# macOS
# -------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -------------------------------------------------------------
# Windows
# -------------------------------------------------------------
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -------------------------------------------------------------
# Logs (general)
# -------------------------------------------------------------
*.log
logs/